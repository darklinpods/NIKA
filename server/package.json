        "prisma": "^5.7.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.4",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
