
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Case {
  id          String   @id @default(uuid())
  title       String
  description String
  priority    String
  status      String   @default("todo") // 'todo', 'in-progress', 'done'
  tags        String   // stored as JSON string
  clientName  String
  parties     String?  // stored as JSON string containing detailed party information
  courtName   String?
  aiSummary   String?
  claimData   String?  // 持久化保存用户编辑的索赔清单文本 (Markdown)
  caseType    String   @default("general") // 案件类型/案由，例如 traffic_accident
  caseFactSheet String? // 结构化案件事实摘要（JSON字符串），AI提取后律师审核存储
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  subTasks    SubTask[]
  documents   CaseDocument[]
  chatMessages CaseChatMessage[]
}

model SubTask {
  id          String   @id @default(uuid())
  title       String
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model CaseDocument {
  id          String   @id @default(uuid())
  title       String
  content     String
  category    String
  createdAt   DateTime @default(now())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model CaseChatMessage {
  id        String   @id @default(uuid())
  role      String   // 'user' or 'assistant'
  content   String
  createdAt DateTime @default(now())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

// 全局知识库/经验库（用于存放 NotebookLM 导出的笔记、法律解读、类案参考）
model KnowledgeDocument {
  id          String   @id @default(uuid())
  title       String
  content     String
  category    String   @default("notebook_lm") // "notebook_lm", "law_article", "template"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
