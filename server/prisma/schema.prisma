
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Case {
  id          String   @id @default(uuid())
  title       String
  description String
  priority    String
  status      String   @default("todo") // 'todo', 'in-progress', 'done'
  tags        String   // stored as JSON string
  clientName  String
  parties     String?  // stored as JSON string containing detailed party information
  courtName   String?
  aiSummary   String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  subTasks    SubTask[]
  documents   CaseDocument[]
  chatMessages CaseChatMessage[]
}

model SubTask {
  id          String   @id @default(uuid())
  title       String
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model CaseDocument {
  id          String   @id @default(uuid())
  title       String
  content     String
  category    String
  createdAt   DateTime @default(now())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model CaseChatMessage {
  id        String   @id @default(uuid())
  role      String   // 'user' or 'assistant'
  content   String
  createdAt DateTime @default(now())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}
