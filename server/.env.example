# === 默认模型配置 (必填) ===
# Gemini API Key (推荐提供，用于处理图片OCR和兜底)
GEMINI_API_KEY=your_gemini_api_key_here

# === 数据库配置 ===
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/law_case_manager"

# === 全局多模型配置 (选填) ===
# 支持的值: gemini, openai, deepseek, doubao, qwen
# AI_PROVIDER=gemini

# 如果使用 DeepSeek:
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# （默认使用 base url: https://api.deepseek.com 且 model: deepseek-chat）

# 如果使用 豆包 (Doubao):
# AI_PROVIDER=doubao
# DOUBAO_API_KEY=your_vbdance_api_key_here
# OPENAI_MODEL=ep-xxxxxx-xxxx (必须提供豆包生成的接入点 ID)
# （默认使用 base url: https://ep.api.vbdance.com/api/v3）

# 如果使用 阿里百炼 (Qwen):
AI_PROVIDER=qwen
QWEN_API_KEY=sk-3f7116b8364b4e3ea3d1afb00d5c226d
# （默认使用 base url: https://dashscope.aliyuncs.com/compatible-mode/v1 且 model: qwen-plus）

# 或者自定义兼容 OpenAI 格式的模型 (例如本地的 Ollama, 或者真正的 OpenAI):
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_custom_key_here
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=gpt-4o-mini
