{
  "name": "law-case-manager-root",
  "private": true,
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev": "npm run dev:server & npm run dev:client",
    "build": "npm run build --workspaces",
    "postinstall": "prisma generate --schema=server/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=server/prisma/schema.prisma"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "@google/genai": "^1.40.0",
    "@prisma/client": "^5.7.0",
    "prisma": "^5.7.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.4",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17"
  }
}