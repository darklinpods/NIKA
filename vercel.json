{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/client/$1"
        }
    ],
    "redirects": [
        {
            "source": "/server",
            "destination": "/api",
            "permanent": true
        }
    ]
}